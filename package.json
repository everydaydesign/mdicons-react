{
  "name": "mdicons-react",
  "version": "0.0.1",
  "description": "Material Design Icons as tree-shakeable React components: import { Home } from \"mdicons-react\".",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "scripts": {
    "generate": "node scripts/generate.mjs",
    "build": "tsup src/index.ts --format esm,cjs --dts --treeshake",
    "prepublishOnly": "npm run generate && npm run build"
  },
  "keywords": [
    "material design icons",
    "mdi",
    "react",
    "icons",
    "svg",
    "tree-shakeable"
  ],
  "license": "Apache-2.0",
  "author": "everydaydesign",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/everydaydesign/mdicons-react.git"
  },
  "homepage": "https://github.com/everydaydesign/mdicons-react#readme",
  "bugs": {
    "url": "https://github.com/everydaydesign/mdicons-react/issues"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "devDependencies": {
    "@mdi/svg": "^7.4.47",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
